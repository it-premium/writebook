<%= form_with model: [ book, page ], id: "page-editor" do |form| %>
  <h1 class="margin-none"><%= form.text_field :title, required: true, autofocus: true, class: "input full-width" %></h1>
  <%= form.text_area :body, class: "input editor margin-block-half", contenteditable: true %>
  <%= form.submit "Save", hidden: true %>
<% end %>
